                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "orders"
                ],
                "summary": "Оформить заказ",
                "responses": {
                    "200": {
                        "description": "Заказ успешно оформлен",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
