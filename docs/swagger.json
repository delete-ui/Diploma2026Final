{
    "consumes": [
        "application/json"
    ],
    "produces": [
        "application/json"
    ],
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "API для интернет-магазина автомобильных аккумуляторов.\nПредоставляет функциональность для регистрации, аутентификации,\nпросмотра каталога аккумуляторов, управления корзиной,\nизбранным и оформления заказов(дипломная версия, non-production).\nВ связи с дипломной версией сервера все коды подтверждения выводятся в логи или в песочнице аккаунта mailtrap.",
        "title": "Battery Shop API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api",
    "paths": {
        "/batteries": {
            "get": {
                "description": "Возвращает список всех доступных аккумуляторов с пагинацией.\nПо умолчанию возвращает 20 записей на странице, максимум 100.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "batteries"
                ],
                "summary": "Список аккумуляторов",
                "parameters": [
                    {
                        "minimum": 1,
                        "type": "integer",
                        "default": 1,
                        "description": "Номер страницы (начиная с 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "maximum": 100,
                        "minimum": 1,
                        "type": "integer",
                        "default": 20,
                        "description": "Количество записей на странице",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список аккумуляторов с пагинацией",
                        "schema": {
                            "$ref": "#/definitions/service.BatteryListResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/cart": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
